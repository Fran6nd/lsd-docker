#!/bin/sh
# lsdctl -- manage the dockerized LSD server
set -eu

DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
cd "$DIR"

usage() {
	cat <<'EOF'
usage: lsdctl <command> [args]

service
  up                  build if needed and start the server
  down                stop the server
  restart             restart the server (applies config/.env changes)
  reload [msg]        warn players in-game, then restart (reloads scripts)
  status              show container state and published ports
  logs [-f]           show server logs (-f to follow)
  update              pull upstream source, rebuild, restart if changed
  console             attach to the in-game admin console (Ctrl-C to leave)
  shell               open a shell inside the container

content
  map list            list installed maps
  map add <src>...    install maps from local files or http(s) URLs
  map rm <name>...    remove maps
  map load <name>     switch the live map now (no restart, no disconnects)
  gamemode [name]     show or set the gamemode (ctf, arena, babel, ...)
  set KEY VALUE       set any .env setting (LSD_PORT, LSD_NAME, LSD_MAPS, ...)

scripts (hotloading, no restart -- players stay connected)
  load [module...]    sync scripts.local/ into the running server and
                      hot-(re)load the modules (no args: reload them all)
  unload <module>...  unload modules from the running server
  lsmod               list modules loaded in the running server

Custom or overriding scripts go in scripts.local/ (same filename as an
upstream script overrides it); apply them with load, or on restart.
EOF
	exit "${1:-0}"
}

# read current value of a .env key, empty if unset
env_get() {
	[ -f .env ] && sed -n "s/^$1=//p" .env | tail -1 || true
}

# set KEY to VALUE in .env, replacing any previous line
env_set() {
	touch .env
	grep -v "^$1=" .env > .env.tmp || true
	printf '%s=%s\n' "$1" "$2" >> .env.tmp
	mv .env.tmp .env
	echo "$1=$2"
}

# pipe stdin into the in-game admin console, relaying its replies
console_pipe() {
	docker compose exec -T lsd socat - UNIX-CONNECT:rw/console.sock
}

# reassemble the running container's scripts/ dir (same recipe as the
# entrypoint) so hotloads pick up the current scripts.local/ contents
scripts_sync() {
	docker compose exec -T lsd sh -c \
		'find scripts -mindepth 1 -delete
		 cp -R scripts.dist/. scripts/
		 [ ! -d scripts.local ] || cp -R scripts.local/. scripts/'
}

# "scripts.local/foo.lua" and "foo" both name the module foo
module_name() {
	basename "$1" .lua
}

cmd=${1:-}
[ -n "$cmd" ] || usage 1
shift

case "$cmd" in
up)
	docker compose up -d --build "$@"
	;;
down)
	docker compose down "$@"
	;;
restart)
	docker compose up -d --force-recreate
	;;
reload)
	notice=${1:-"server reboots in 5 seconds to reload scripts, hold on..."}
	# announce, wait, then have the server exit itself: its clean
	# shutdown hooks run and the container's restart policy brings it
	# back up (and reassembles scripts/) without any docker call here.
	# The dying server breaks the console pipe, so success is checked
	# by the container's start timestamp, not the pipe status.
	cid=$(docker compose ps -q lsd)
	born=$(docker inspect -f '{{.State.StartedAt}}' "$cid")
	{
		printf 'say %s\n' "$notice"
		sleep 5
		printf 'exec os.exit(0)\n'
		sleep 1
	} | console_pipe >/dev/null 2>&1 || true
	sleep 2
	if [ "$(docker inspect -f '{{.State.StartedAt}}' "$cid")" = "$born" ]; then
		echo "console did not take the server down, restarting the hard way" >&2
		docker compose restart lsd
	fi
	docker compose ps --format 'table {{.Name}}\t{{.State}}\t{{.Status}}'
	;;
status)
	docker compose ps --format 'table {{.Name}}\t{{.State}}\t{{.Status}}\t{{.Publishers}}'
	;;
logs)
	docker compose logs "$@"
	;;
update)
	exec ./update.sh
	;;
console)
	docker compose exec lsd socat READLINE UNIX-CONNECT:rw/console.sock
	;;
shell)
	docker compose exec lsd ash
	;;
load)
	# catch typos before touching the server
	for name in "$@"; do
		name=$(module_name "$name")
		if [ ! -f "lsd/scripts/$name.lua" ] && [ ! -f "scripts.local/$name.lua" ]; then
			echo "error: no module '$name' (no $name.lua in lsd/scripts/ or scripts.local/)" >&2
			exit 1
		fi
	done
	scripts_sync
	{
		if [ $# -eq 0 ]; then
			echo reloadall
		else
			for name in "$@"; do
				printf 'load %s\n' "$(module_name "$name")"
			done
		fi
		# keep the socket open a moment to catch the replies
		sleep 1
	} | console_pipe
	;;
unload)
	[ $# -gt 0 ] || usage 1
	{
		for name in "$@"; do
			printf 'unload %s\n' "$(module_name "$name")"
		done
		sleep 1
	} | console_pipe
	;;
lsmod)
	{ echo lsmod; sleep 1; } | console_pipe
	;;
map)
	sub=${1:-list}; [ $# -gt 0 ] && shift
	case "$sub" in
	list)
		ls -lh maps/*.vxl 2>/dev/null || echo "no maps installed"
		;;
	add)
		[ $# -gt 0 ] || usage 1
		mkdir -p maps
		for src in "$@"; do
			case "$src" in
			http://*|https://*)
				curl -fSL -o "maps/$(basename "$src")" "$src";;
			*)
				cp -v "$src" maps/;;
			esac
		done
		echo "installed; maps are picked up at the next rotation," \
		     "add them to LSD_MAPS to queue them: ./lsdctl set LSD_MAPS '...'"
		;;
	rm)
		[ $# -gt 0 ] || usage 1
		for name in "$@"; do
			rm -v "maps/${name%.vxl}.vxl"
		done
		;;
	load)
		[ $# -eq 1 ] || usage 1
		name=${1%.vxl}
		if [ ! -f "maps/$name.vxl" ]; then
			echo "error: no map 'maps/$name.vxl' (see ./lsdctl map list)" >&2
			exit 1
		fi
		# switch the running server's map now -- no restart, nobody
		# disconnects; the in-game loadmap takes the name, not the path
		{ printf 'loadmap %s\n' "$name"; sleep 1; } | console_pipe
		;;
	*)
		usage 1;;
	esac
	;;
gamemode)
	if [ $# -eq 0 ]; then
		mode=${LSD_GAMEMODE:-$(env_get LSD_GAMEMODE)}
		echo "${mode:-ctf}"
	else
		# catch typos here instead of a container restart loop
		if [ ! -f "lsd/scripts/$1.lua" ] && [ ! -f "scripts.local/$1.lua" ]; then
			echo "error: no gamemode '$1' (no $1.lua in lsd/scripts/ or scripts.local/)" >&2
			exit 1
		fi
		env_set LSD_GAMEMODE "$1"
		docker compose up -d --force-recreate
	fi
	;;
set)
	[ $# -eq 2 ] || usage 1
	env_set "$1" "$2"
	docker compose up -d --force-recreate
	;;
help|-h|--help)
	usage
	;;
*)
	usage 1
	;;
esac
